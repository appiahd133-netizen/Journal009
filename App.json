{
  "expo": {
    "name": "Forex Journal",
    "slug": "forex-journal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0C0F",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0C0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.forexjournal.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to attach screenshots to your trades.",
        "NSPhotoLibraryUsageDescription": "Used to save and share trade screenshots."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0C0F"
      },
      "package": "com.forexjournal.app",
      "versionCode": 1,
      "permissions": ["READ_EXTERNAL_STORAGE","WRITE_EXTERNAL_STORAGE","CAMERA","VIBRATE"],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": { "favicon": "./assets/favicon.png" },
    "plugins": ["expo-font","expo-splash-screen"],
    "extra": { "eas": { "projectId": "your-eas-project-id" } }
  }
}

